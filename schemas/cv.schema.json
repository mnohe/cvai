{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mnohe.github.io/cvai/schemas/cv.schema.json",
  "title": "CVAI CV Format",
  "description": "Public JSON Schema for CVAI CV source data. CVAI stores candidate CVs as structured YAML or JSON matching this schema, then renders them through CVAI templates.",
  "$comment": "CVAI repository: https://github.com/mnohe/cvai",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "contact",
    "languages",
    "certifications",
    "education",
    "experience",
    "projects"
  ],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "contact": {
      "$ref": "#/$defs/contact"
    },
    "languages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/language"
      }
    },
    "certifications": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/certification"
      }
    },
    "education": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/education"
      }
    },
    "experience": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/experienceEntry"
      }
    },
    "projects": {
      "$ref": "#/$defs/projects"
    }
  },
  "$defs": {
    "contact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "surname",
        "phone",
        "email",
        "linkedin"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "surname": {
          "type": "string",
          "minLength": 1
        },
        "phone": {
          "$ref": "#/$defs/phone"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "linkedin": {
          "type": "string",
          "minLength": 1
        },
        "github": {
          "type": "string",
          "minLength": 1
        },
        "www": {
          "type": "string",
          "format": "uri",
          "minLength": 1
        }
      }
    },
    "phone": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prefix",
        "number"
      ],
      "properties": {
        "prefix": {
          "type": "string",
          "pattern": "^\\+[0-9]{1,4}$"
        },
        "number": {
          "type": "string",
          "minLength": 3
        }
      }
    },
    "language": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "level"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "level": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "certification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "issuer"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "issuer": {
          "type": "string",
          "minLength": 1
        },
        "year": {
          "type": "integer",
          "minimum": 1900,
          "maximum": 2100
        }
      }
    },
    "education": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "issuer"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "issuer": {
          "type": "string",
          "minLength": 1
        },
        "year": {
          "type": "integer",
          "minimum": 1900,
          "maximum": 2100
        }
      }
    },
    "experienceEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "company",
        "positions"
      ],
      "properties": {
        "company": {
          "type": "string",
          "minLength": 1
        },
        "visible": {
          "type": "boolean",
          "default": true
        },
        "positions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/position"
          }
        }
      }
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "roles",
        "start",
        "location",
        "tasks"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "minLength": 1
        },
        "roles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "start": {
          "type": "string",
          "pattern": "^[0-9]{4}(-[0-9]{2}(-[0-9]{2})?)?$"
        },
        "end": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9]{4}(-[0-9]{2}(-[0-9]{2})?)?$"
        },
        "location": {
          "type": "string",
          "minLength": 1
        },
        "tasks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "projects": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "items"
      ],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/projectItem"
          }
        }
      }
    },
    "projectItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "summary",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "visible": {
          "type": "boolean",
          "default": true
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "url"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri",
          "minLength": 1
        }
      }
    }
  }
}
