rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function validCandidateProfile() {
      return !("preferences" in request.resource.data) ||
        request.resource.data.preferences == null ||
        (request.resource.data.preferences is string &&
          request.resource.data.preferences.size() <= 2000);
    }

    match /users/{uid}/candidate/profile {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid) && validCandidateProfile();
    }
    match /users/{uid}/account/profile {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/{collection}/{document} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid) &&
        (collection != "candidate" || document != "profile") &&
        (collection != "account" || document != "profile");
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
