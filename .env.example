# CVAI reads all persistent state from this writable directory.
CVAI_DATA=/data

# HTTP runtime configuration.
HOST=0.0.0.0
PORT=8080

# LLM provider configuration. Any OpenAI-compatible endpoint can be used by
# setting the base URL and model name.
LLM_API_KEY=
LLM_MODEL=gpt-5
LLM_BASE_URL=https://api.openai.com/v1

# Provider-specific values may be added later only when a provider needs them.
