rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function validCandidateProfile() {
      return !("preferences" in request.resource.data) ||
        request.resource.data.preferences == null ||
        (request.resource.data.preferences is string &&
          request.resource.data.preferences.size() <= 2000);
    }

    function isAdmin() {
      return request.auth != null &&
        request.auth.uid in
          get(/databases/$(database)/documents/_admin/admins).data.uids;
    }

    match /users/{uid}/candidate/profile {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid) && validCandidateProfile();
    }
    match /users/{uid}/{collection}/{document} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid) && (collection != "candidate" || document != "profile");
    }
    // Documents deeper than users/{uid}/{collection}/{document} are intentionally
    // denied by the final catch-all. Add an explicit rule when a user subtree
    // feature needs nested documents.
    match /_admin/admins {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /_admin/config {
      allow read, write: if isAdmin();
    }
    match /_admin/log/entries/{entry} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
    match /_admin/{document=**} {
      allow read, write: if false;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
