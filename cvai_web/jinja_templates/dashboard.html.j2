{% extends "base.html.j2" %}

{% block body %}
<section class="role-list" style="margin-bottom:24px;">
  {% for role in roles %}
    {% set role_record = role.role %}
    {% set badge = dashboard_status_badge(role_record) %}
    {% set task_label = "open task" if role.open_task_count == 1 else "open tasks" %}
    <article class="role-row">
      <div>
        <div class="role-title-line">
          <a class="role-title" href="/roles/{{ role_record.canonical_slug }}">{{ role_record.role }}</a>
          <span class="pill {{ badge[1] }}">{{ badge[0] }}</span>
          {% if role.open_task_count %}
            <span class="task-notice">{{ role.open_task_count }} {{ task_label }}</span>
          {% endif %}
        </div>
        <div class="role-subtitle">{{ role_record.company }}, {{ role_record.location }}</div>
        <div class="role-meta">
          <span class="muted">{{ role_record.role_status|status_sentence }}</span>
        </div>
      </div>
      <div class="row-actions">
        <a href="/roles/{{ role_record.canonical_slug }}">Details</a>
        <button
	          type="button"
	          data-title="{{ role_record.company }} · {{ role_record.role }}"
	          data-target-id="{{ role_record.canonical_slug }}"
	          onclick="openRoleUpdateDialog(this.dataset.title, this.dataset.targetId)"
	        >Update</button>
      </div>
    </article>
  {% else %}
    <div class="list-item muted">No active roles found.</div>
  {% endfor %}
</section>

<dialog class="dialog" id="role-update-dialog">
  <form method="dialog" style="margin-bottom:14px;">
    <div class="toolbar" style="justify-content:space-between;align-items:flex-start;">
      <h3 id="role-update-title">Update role</h3>
      <button type="submit">Close</button>
    </div>
  </form>
	  <form id="role-update-form" method="post" action="/actions" hx-post="/actions" hx-target="#operation-notice-root" hx-swap="outerHTML">
	    <input type="hidden" name="action_type" value="role_update_prompt">
	    <input type="hidden" name="target_type" value="role">
	    <input type="hidden" name="target_id" value="">
	    <label>Update prompt
	      <textarea name="prompt" required rows="2" placeholder="Rejected on 2026-05-16 with this rationale: ..."></textarea>
    </label>
    <button class="primary" type="submit">Apply update</button>
  </form>
</dialog>
<script>
	  function openRoleUpdateDialog(title, targetId) {
	    const dialog = document.getElementById("role-update-dialog");
	    document.getElementById("role-update-title").textContent = title;
	    const form = document.getElementById("role-update-form");
	    form.querySelector('input[name="target_id"]').value = targetId;
	    dialog.showModal();
	  }
</script>

{% endblock %}
