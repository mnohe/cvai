{% extends "base.html.j2" %}

{% block body %}
<section class="split">
  <article class="card">
    <h3>From URL</h3>
    <form method="post" action="/ingestions/url" hx-post="/ingestions/url" hx-target="#operation-modal-root" hx-swap="outerHTML">
      <label class="checkbox-row">
        <input type="checkbox" name="quick_analysis" value="1" checked>
        Quick analysis before full ingestion
      </label>
      <label>Role URL
        <input type="url" name="source_url" required placeholder="https://company.example/jobs/role">
      </label>
      <button class="primary" type="submit">Start URL ingestion</button>
    </form>
  </article>
  <article class="card">
    <h3>From pasted text</h3>
    <form method="post" action="/ingestions/text" hx-post="/ingestions/text" hx-target="#operation-modal-root" hx-swap="outerHTML">
      <label class="checkbox-row">
        <input type="checkbox" name="quick_analysis" value="1" checked>
        Quick analysis before full ingestion
      </label>
      <label>Source URL
        <input type="url" name="source_url" placeholder="Optional but helpful">
      </label>
      <label>Company override
        <input type="text" name="company" placeholder="Optional">
      </label>
      <label>Location override
        <input type="text" name="location" placeholder="Optional">
      </label>
      <label>Role title override
        <input type="text" name="role" placeholder="Optional">
      </label>
      <label>Job description text
        <textarea name="source_text" required placeholder="Paste the role page text here"></textarea>
      </label>
      <button class="primary" type="submit">Start pasted-text ingestion</button>
    </form>
  </article>
</section>
{% endblock %}
