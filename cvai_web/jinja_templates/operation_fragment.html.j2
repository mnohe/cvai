<section
  id="operation-status"
  {% if not finished %}
    hx-get="/operations/{{ operation.id }}/fragment"
    hx-trigger="load delay:3s, every 3s"
    hx-swap="outerHTML"
  {% endif %}
>
  {% include "operation_badge_oob.html.j2" %}
  {% include "operation_status_badge_oob.html.j2" %}
  {% include "operation_summary_text_oob.html.j2" %}

  {% if operation.result and operation.result.quick_analysis %}
    <article class="card operation-result-card">
      <h3>Quick analysis completed</h3>
      <p class="muted">Return to the intake page to continue or abandon this role.</p>
    </article>
  {% elif operation.result %}
    <article class="card" style="margin-bottom:24px;">
      <h3>Created files</h3>
      <div class="list">
        {% if operation.result.paths %}
          {% for path in operation.result.paths.values() %}
            <div class="list-item"><code>{{ path }}</code></div>
          {% endfor %}
        {% endif %}
      </div>
      {% if operation.result.canonical_slug %}
        <div class="toolbar" style="margin-top:14px;">
          <a class="button primary" href="/roles/{{ operation.result.canonical_slug }}">Open role</a>
        </div>
      {% endif %}
    </article>
  {% endif %}

  <article class="card">
    <h3>Operation log</h3>
    <pre>{{ operation.log }}</pre>
  </article>
</section>
