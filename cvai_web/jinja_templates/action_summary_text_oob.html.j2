<p id="operation-page-summary" hx-swap-oob="outerHTML">
  {% if finished %}
    {{ operation.kind|replace("_", " ")|title }} finished with status {{ operation.status }}.
  {% else %}
    {{ operation.kind|replace("_", " ")|title }} is running in the background. This page updates while the action is active.
  {% endif %}
</p>
