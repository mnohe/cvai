<div id="operation-modal-root">
  {% include "action_badge_oob.html.j2" %}
  <dialog class="dialog operation-dialog" id="operation-modal">
    <div class="modal-header">
      <div>
        <h3>Quick analysis</h3>
      </div>
      {% if not finished %}
        <form method="post" action="/actions/{{ operation.id }}" hx-patch="/actions/{{ operation.id }}" hx-target="#operation-modal-root" hx-swap="outerHTML">
          <input type="hidden" name="status" value="cancelled">
          <button type="submit">Cancel</button>
        </form>
      {% else %}
        <form method="dialog">
          <button type="submit" onclick="document.getElementById('operation-modal-root').innerHTML = ''">Close</button>
        </form>
      {% endif %}
    </div>

    <div
      id="operation-modal-body"
      {% if not finished %}
        hx-get="/actions/{{ operation.id }}/modal"
        hx-trigger="load delay:2s, every 2s"
        hx-target="#operation-modal-root"
        hx-swap="outerHTML"
      {% endif %}
    >
      {% if not finished %}
        <p class="muted">Analyzing the role fit...</p>
      {% elif operation.status == "cancelled" %}
        <p>Action cancelled.</p>
      {% elif operation.result and operation.result.quick_analysis %}
        {% include "action_quick_analysis.html.j2" %}
      {% elif operation.status == "failed" %}
        <div class="flash error">{{ operation.error or "Action failed." }}</div>
      {% endif %}
    </div>
  </dialog>
</div>
