{% extends "base.html.j2" %}

{% block body %}
<article class="card">
  <table class="event-table">
    <thead><tr><th>Name</th><th>Status</th><th>ETA</th><th>Gap</th></tr></thead>
    <tbody>
      {% for task in tasks %}
        <tr>
          <td><a class="download-link" href="/tasks/{{ task.id }}">{{ task.title }}</a></td>
          <td><span class="pill {{ task.status|task_status_class }}">{{ task.status|task_status_label }}</span></td>
          <td class="muted">{{ task|task_eta_label }}</td>
          <td>{{ task.description }}</td>
        </tr>
      {% else %}
        <tr><td colspan="4" class="muted">No open tasks recorded yet.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</article>
{% endblock %}
