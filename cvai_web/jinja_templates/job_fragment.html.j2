<section
  id="job-status"
  {% if not finished %}
    hx-get="/jobs/{{ job.id }}/fragment"
    hx-trigger="load delay:3s, every 3s"
    hx-swap="outerHTML"
  {% endif %}
>
  <div class="toolbar" style="justify-content:flex-end;margin-bottom:18px;">
    <span class="pill">{{ job.status }}</span>
  </div>

  {% if job.result and job.result.quick_analysis %}
    {% set quick = job.result.quick_analysis %}
    <article class="card" style="margin-bottom:24px;">
      <h3>Quick analysis</h3>
      <dl class="meta">
        <dt>Fit</dt>
        <dd>{{ quick.fit_level|replace("_", " ")|title }}</dd>
        <dt>Recommendation</dt>
        <dd>{{ quick.recommendation|replace("_", " ")|title }}</dd>
      </dl>
      {% if quick.summary %}
        <p>{{ quick.summary }}</p>
      {% endif %}
      {% if quick.key_matching_abilities %}
        <h4>Matching abilities</h4>
        <ul>
          {% for ability in quick.key_matching_abilities %}
            <li>{{ ability }}</li>
          {% endfor %}
        </ul>
      {% endif %}
      {% if quick.important_gaps %}
        <h4>Important gaps</h4>
        <div class="list">
          {% for gap in quick.important_gaps %}
            <div class="list-item">
              <strong>{{ gap.requirement }}</strong>
              <span>{{ gap.category|default("inferred_requirement")|replace("_", " ") }} · {{ gap.fulfillment|default("unknown") }} · {{ gap.estimated_effort|default("unknown effort") }}</span>
            </div>
          {% endfor %}
        </div>
      {% endif %}
      {% if quick.rationale %}
        <p>{{ quick.rationale }}</p>
      {% endif %}
      {% if not job.result.abandoned %}
        <div class="toolbar" style="margin-top:14px;">
          <form method="post" action="/jobs/{{ job.id }}/continue-ingestion">
            <button class="primary" type="submit">Continue full ingestion</button>
          </form>
          <form method="post" action="/jobs/{{ job.id }}/abandon">
            <button type="submit">Abandon</button>
          </form>
        </div>
      {% else %}
        <div class="flash">Quick analysis abandoned. No role files were written.</div>
      {% endif %}
    </article>
  {% elif job.result %}
    <article class="card" style="margin-bottom:24px;">
      <h3>Created files</h3>
      <div class="list">
        {% if job.result.paths %}
          {% for path in job.result.paths.values() %}
            <div class="list-item"><code>{{ path }}</code></div>
          {% endfor %}
        {% endif %}
      </div>
      <div class="toolbar" style="margin-top:14px;">
        <a class="button primary" href="/roles/{{ job.result.canonical_slug }}">Open role</a>
      </div>
    </article>
  {% endif %}

  <article class="card">
    <h3>Job log</h3>
    <pre>{{ job.log }}</pre>
  </article>
</section>
