{
  "name": "CVAI",
  "build": {
    "dockerfile": "Dockerfile"
  },

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:3.0.1": {}
  },

  "postCreateCommand": "bash .devcontainer/post-create.sh",

  "customizations": {
    "vscode": {
      "settings": {
        "[go]": {
          "editor.formatOnSave": true,
          "editor.defaultFormatter": "golang.go",
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          }
        }
      },
      "extensions": [
        "golang.go",
        "Firebase.vscode-firebase-explorer",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "Anthropic.claude-code",
        "openai.chatgpt"
      ]
    }
  },

  "forwardPorts": [4000, 5000, 8080, 8081, 9099, 9199],
  "portsAttributes": {
    "4000": { "label": "Firebase Emulator UI" },
    "5000": { "label": "Firebase Hosting" },
    "8080": { "label": "Firestore Emulator" },
    "8081": { "label": "Go Backend" },
    "9099": { "label": "Firebase Auth" },
    "9199": { "label": "Firebase Storage" }
  },

  "remoteEnv": {
    "FIRESTORE_EMULATOR_HOST": "localhost:8080",
    "FIREBASE_AUTH_EMULATOR_HOST": "localhost:9099",
    "FIREBASE_PROJECT_ID": "demo-cvai"
  }
}
